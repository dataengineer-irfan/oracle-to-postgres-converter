# Environment Configuration
# Copy this file to .env and fill in your PostgreSQL credentials.
# The .env file must be placed in the same directory as converter.py.

# ── PostgreSQL Connection ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Target Schema ─────────────────────────────────────────────────────────
# All tables will be created under this schema.
PG_SCHEMA=provider

# ── Runtime Flags ─────────────────────────────────────────────────────────
# Set to false to only convert DDL without connecting to the database.
EXECUTE_DDL=true

# Set to false to skip loading sample rows from input/data/*.csv
LOAD_SAMPLE_DATA=true
